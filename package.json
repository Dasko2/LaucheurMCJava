{
  "name": "laucheurjava",
  "version": "1.1.0",
  "description": "Minecraft Launcher Electron Fabric Mods",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.5.2",
    "fs-extra": "^11.2.0",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.laucheurjava.launcher",
    "productName": "LaucheurJava",
    "files": ["**/*"],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  }
}
